{
	"$schema": "https://turborepo.com/schema.v2.json",
	"extends": ["//"],
	"tasks": {
		"build:dev": {
			"cache": true,
			"dependsOn": ["^build:dev"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"$TURBO_ROOT$/package.json",
				"$TURBO_ROOT$/pnpm-lock.yaml",
				"$TURBO_ROOT$/pnpm-workspace.yaml",
				"src/**",
				"bin/**",
				"!__test__/**",
				"package.json",
				"tsdown.config.ts",
				"tsconfig.json"
			],
			"outputLogs": "full",
			"outputs": ["dist/**"]
		},
		"build:prod": {
			"cache": true,
			"dependsOn": ["^build:prod"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"$TURBO_ROOT$/package.json",
				"$TURBO_ROOT$/pnpm-lock.yaml",
				"$TURBO_ROOT$/pnpm-workspace.yaml",
				"src/**",
				"bin/**",
				"package.json",
				"tsdown.config.ts",
				"tsconfig.json"
			],
			"outputLogs": "full",
			"outputs": ["dist/**"]
		},
		"types:check": {
			"cache": true,
			"dependsOn": [],
			"inputs": [
				"$TURBO_DEFAULT$",
				"$TURBO_ROOT$/package.json",
				"$TURBO_ROOT$/pnpm-lock.yaml",
				"$TURBO_ROOT$/pnpm-workspace.yaml",
				"__test__/**",
				"src/**",
				"bin/**",
				"package.json",
				"tsdown.config.ts",
				"tsconfig.json"
			],
			"outputLogs": "full",
			"outputs": ["dist/.tsbuildinfo.lib"]
		}
	}
}
