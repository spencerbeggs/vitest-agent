{
	"name": "vitest-agent-sidecar-win32-x64",
	"version": "1.3.1",
	"private": true,
	"description": "win32-x64 prebuilt binary for vitest-agent-sidecar.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/vitest-agent.git",
		"directory": "packages/sidecar-win32-x64"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"exports": {
		".": "./src/bin.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:meta": "echo 'no op'",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "turbo run build:dev --filter=vitest-agent-sidecar-win32-x64",
		"types:check": "tsgo --noEmit"
	},
	"devDependencies": {
		"@savvy-web/bundler": "^0.6.0",
		"@types/node": "catalog:silk",
		"@typescript/native-preview": "catalog:silk",
		"typescript": "catalog:silk",
		"vitest-agent-sdk": "workspace:*"
	},
	"os": ["win32"],
	"cpu": ["x64"],
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true,
			"github": "@spencerbeggs/vitest-agent-sidecar-win32-x64"
		}
	}
}
