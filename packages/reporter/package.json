{
	"name": "vitest-agent-reporter",
	"version": "1.3.1",
	"private": true,
	"description": "Named VitestAgentReporterFactory implementations for the vitest-agent ecosystem.",
	"keywords": ["vitest", "reporter", "llm", "ai", "agent", "testing", "coverage", "markdown", "github-actions"],
	"homepage": "https://github.com/spencerbeggs/vitest-agent#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/vitest-agent/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/vitest-agent.git",
		"directory": "packages/reporter"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:meta": "node savvy.build.ts --target meta",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "node savvy.build.ts --target dev",
		"types:check": "tsgo --noEmit"
	},
	"dependencies": {
		"@effect/cluster": "catalog:silk",
		"@effect/platform": "catalog:silk",
		"@effect/platform-node": "catalog:silk",
		"@effect/rpc": "catalog:silk",
		"@effect/sql": "catalog:silk",
		"@effect/sql-sqlite-node": "catalog:silk",
		"effect": "catalog:silk",
		"ink": "^7.0.5",
		"react": "catalog:silk",
		"vitest-agent-sdk": "workspace:*",
		"vitest-agent-ui": "workspace:*"
	},
	"devDependencies": {
		"@savvy-web/bundler": "^0.6.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "catalog:silk",
		"@types/react": "catalog:silk",
		"@typescript/native-preview": "catalog:silk",
		"@vitest/coverage-istanbul": "^4.1.8",
		"@vitest/coverage-v8": "^4.1.8",
		"better-sqlite3": "^12.10.0",
		"typescript": "catalog:silk",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"peerDependencies": {
		"@vitest/coverage-istanbul": "^4.1.0",
		"@vitest/coverage-v8": "^4.1.0",
		"vitest": "^4.1.0"
	},
	"peerDependenciesMeta": {
		"@vitest/coverage-istanbul": {
			"optional": true
		},
		"@vitest/coverage-v8": {
			"optional": true
		},
		"vitest": {
			"optional": false
		}
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true,
			"github": "@spencerbeggs/vitest-agent-reporter"
		}
	}
}
