{
	"name": "@vitest-agent/sidecar-darwin-arm64",
	"version": "0.0.0",
	"private": true,
	"description": "darwin-arm64 prebuilt binary for vitest-agent-sidecar.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/vitest-agent.git",
		"directory": "packages/sidecar-darwin-arm64"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"exports": {
		".": "./src/bin.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "turbo run build:dev",
		"types:check": "tsgo --noEmit"
	},
	"devDependencies": {
		"@savvy-web/bundler": "^0.11.0",
		"@types/node": "catalog:silk",
		"@typescript/native-preview": "catalog:silk",
		"@vitest-agent/sdk": "workspace:*",
		"typescript": "catalog:silk"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"os": ["darwin"],
	"cpu": ["arm64"],
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
