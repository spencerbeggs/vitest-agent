{
	"name": "vitest-agent-sidecar-darwin-arm64",
	"version": "0.0.0",
	"private": true,
	"description": "darwin-arm64 prebuilt binary for vitest-agent-sidecar.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/vitest-agent.git",
		"directory": "packages/sidecar-darwin-arm64"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"bin": {
		"vitest-agent-sidecar": "./bin/vitest-agent-sidecar"
	},
	"files": ["bin/vitest-agent-sidecar"],
	"scripts": {
		"build:dev": "tsdown --config tsdown.config.ts",
		"build:prod": "exit 0",
		"types:check": "exit 0"
	},
	"devDependencies": {
		"@tsdown/exe": "^0.22.0",
		"tsdown": "^0.22.0",
		"vitest-agent-cli": "workspace:*",
		"vitest-agent-sdk": "workspace:*"
	},
	"os": ["darwin"],
	"cpu": ["arm64"],
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev",
		"linkDirectory": true,
		"targets": [
			{
				"protocol": "npm",
				"registry": "https://npm.pkg.github.com/",
				"directory": "dist/github",
				"access": "public",
				"provenance": true
			},
			{
				"protocol": "npm",
				"registry": "https://registry.npmjs.org/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			}
		]
	}
}
