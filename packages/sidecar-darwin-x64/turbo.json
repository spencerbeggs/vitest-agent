{
	"$schema": "https://turborepo.com/schema.v2.json",
	"extends": ["//"],
	"tasks": {
		"build:dev": {
			"cache": true,
			"dependsOn": ["^build:dev"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"$TURBO_ROOT$/package.json",
				"$TURBO_ROOT$/pnpm-lock.yaml",
				"$TURBO_ROOT$/pnpm-workspace.yaml",
				"src/**",
				"lib/**",
				"package.json",
				"README.md",
				"LICENSE"
			],
			"outputLogs": "full",
			"outputs": ["dist/dev/**"]
		},
		"build:prod": {
			"cache": true,
			"dependsOn": ["build:dev"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"$TURBO_ROOT$/package.json",
				"$TURBO_ROOT$/pnpm-lock.yaml",
				"$TURBO_ROOT$/pnpm-workspace.yaml",
				"src/**",
				"lib/**",
				"package.json",
				"README.md",
				"LICENSE"
			],
			"outputLogs": "full",
			"outputs": ["dist/github/**", "dist/npm/**"]
		},
		"types:check": {
			"cache": true,
			"dependsOn": [],
			"inputs": ["src/**", "package.json", "*.ts"],
			"outputLogs": "full",
			"outputs": ["dist/.tsbuildinfo.lib"]
		}
	}
}
