{
	"name": "@vitest-agent/ui",
	"version": "0.0.0",
	"private": true,
	"description": "Shared event-sourced renderer for vitest-agent. React Ink view for humans, plain-string view for agents, both fed by the same reducer over a RunEvent stream.",
	"keywords": ["vitest", "ui", "ink", "react", "llm", "ai", "agent", "testing", "coverage"],
	"homepage": "https://github.com/spencerbeggs/vitest-agent#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/vitest-agent/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/vitest-agent.git",
		"directory": "packages/ui"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:meta": "node savvy.build.ts --target meta",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "node savvy.build.ts --target dev",
		"types:check": "tsgo --noEmit"
	},
	"dependencies": {
		"@vitest-agent/sdk": "workspace:*",
		"effect": "catalog:silk"
	},
	"devDependencies": {
		"@savvy-web/bundler": "^0.6.0",
		"@types/node": "catalog:silk",
		"@types/react": "catalog:silk",
		"@typescript/native-preview": "catalog:silk",
		"ink": "^7.0.5",
		"ink-testing-library": "^4.0.0",
		"react": "catalog:silk",
		"typescript": "catalog:silk",
		"vitest": "^4.1.8"
	},
	"peerDependencies": {
		"ink": "^7.0.0",
		"react": "catalog:silk"
	},
	"peerDependenciesMeta": {
		"ink": {
			"optional": false
		},
		"react": {
			"optional": false
		}
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
