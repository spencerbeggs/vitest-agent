{
	"$schema": "https://turborepo.com/schema.v2.json",
	"extends": ["//"],
	"tasks": {
		"build:dev": {
			"cache": true,
			"dependsOn": ["^build:dev"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"$TURBO_ROOT$/package.json",
				"$TURBO_ROOT$/pnpm-lock.yaml",
				"$TURBO_ROOT$/pnpm-workspace.yaml",
				"$TURBO_ROOT$/vitest.*.ts",
				"$TURBO_ROOT$/lib/**",
				"src/**",
				"lib/**",
				"!__test__/**",
				"package.json",
				"rslib.config.ts",
				"tsconfig.json"
			],
			"outputLogs": "full",
			"outputs": ["dist/dev/**", ".rslib/declarations/dev/**"]
		},
		"build:prod": {
			"cache": true,
			"dependsOn": ["^build:prod"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"$TURBO_ROOT$/package.json",
				"$TURBO_ROOT$/pnpm-lock.yaml",
				"$TURBO_ROOT$/pnpm-workspace.yaml",
				"$TURBO_ROOT$/vitest.*.ts",
				"$TURBO_ROOT$/lib/**",
				"src/**",
				"lib/**",
				"package.json",
				"rslib.config.ts",
				"tsconfig.json"
			],
			"outputLogs": "full",
			"outputs": ["dist/npm/**", ".rslib/declarations/npm/**", "../../website/lib/models/ui/**"]
		},
		"types:check": {
			"cache": true,
			"dependsOn": [],
			"inputs": [
				"$TURBO_DEFAULT$",
				"$TURBO_ROOT$/package.json",
				"$TURBO_ROOT$/pnpm-lock.yaml",
				"$TURBO_ROOT$/pnpm-workspace.yaml",
				"$TURBO_ROOT$/vitest.*.ts",
				"$TURBO_ROOT$/lib/**",
				"__test__/**",
				"src/**",
				"lib/**",
				"package.json",
				"rslib.config.ts",
				"tsconfig.json"
			],
			"outputLogs": "full",
			"outputs": ["dist/.tsbuildinfo.lib"]
		}
	}
}
