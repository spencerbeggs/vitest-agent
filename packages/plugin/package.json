{
	"name": "@vitest-agent/plugin",
	"version": "1.3.1",
	"private": true,
	"description": "Vitest plugin for the vitest-agent ecosystem: owns persistence, classification, baselines, trends, and dispatches rendering to a configurable reporter.",
	"keywords": ["vitest", "vitest-plugin", "agent", "llm", "ai", "testing", "sqlite", "coverage", "mcp"],
	"homepage": "https://github.com/spencerbeggs/vitest-agent#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/vitest-agent/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/vitest-agent.git",
		"directory": "packages/plugin"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:meta": "node savvy.build.ts --target meta",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "turbo run build:dev --filter=.",
		"types:check": "tsgo --noEmit"
	},
	"dependencies": {
		"@effect/cluster": "catalog:silk",
		"@effect/platform": "catalog:silk",
		"@effect/platform-node": "catalog:silk",
		"@effect/rpc": "catalog:silk",
		"@effect/sql": "catalog:silk",
		"@effect/sql-sqlite-node": "catalog:silk",
		"@vitest-agent/reporter": "workspace:*",
		"@vitest-agent/sdk": "workspace:*",
		"acorn": "^8.16.0",
		"acorn-typescript": "^1.4.13",
		"effect": "catalog:silk",
		"magic-string": "^0.30.0",
		"workspaces-effect": "^1.1.0"
	},
	"devDependencies": {
		"@savvy-web/bundler": "^0.6.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "catalog:silk",
		"@typescript/native-preview": "catalog:silk",
		"@vitest/coverage-istanbul": "^4.1.8",
		"@vitest/coverage-v8": "^4.1.8",
		"better-sqlite3": "^12.10.0",
		"typescript": "catalog:silk",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"peerDependencies": {
		"@vitest-agent/cli": "workspace:*",
		"@vitest-agent/mcp": "workspace:*",
		"@vitest/coverage-istanbul": "^4.1.0",
		"@vitest/coverage-v8": "^4.1.0",
		"@vitest/runner": "^4.1.0",
		"vitest": "^4.1.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true,
			"github": "@spencerbeggs/vitest-agent-plugin"
		}
	}
}
