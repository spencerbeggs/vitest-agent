{
	"name": "@vitest-agent/plugin",
	"version": "2.0.5",
	"private": true,
	"description": "Vitest plugin for the vitest-agent ecosystem: owns persistence, classification, baselines, trends, and dispatches rendering to a configurable reporter.",
	"keywords": ["vitest", "vitest-plugin", "agent", "llm", "ai", "testing", "sqlite", "coverage", "mcp"],
	"homepage": "https://github.com/spencerbeggs/vitest-agent#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/vitest-agent/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/vitest-agent.git",
		"directory": "packages/plugin"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "turbo run build:dev",
		"types:check": "tsc --noEmit"
	},
	"dependencies": {
		"@effect/platform-node": "catalog:effect",
		"@effect/sql-sqlite-node": "catalog:effect",
		"@effected/workspaces": "^0.6.0",
		"@vitest-agent/cli": "workspace:*",
		"@vitest-agent/mcp": "workspace:*",
		"@vitest-agent/reporter": "workspace:*",
		"@vitest-agent/sdk": "workspace:*",
		"effect": "catalog:effect",
		"magic-string": "^1.0.0"
	},
	"devDependencies": {
		"@savvy-web/bundler": "^2.0.5",
		"@types/node": "catalog:silk",
		"@vitest/coverage-istanbul": "catalog:silk",
		"@vitest/coverage-v8": "catalog:silk",
		"@vitest/runner": "^4.1.10",
		"typescript": "catalog:silk",
		"vite": "^8.1.5",
		"vitest": "catalog:silk"
	},
	"peerDependencies": {
		"@vitest/coverage-istanbul": "catalog:silkPeers",
		"@vitest/coverage-v8": "catalog:silkPeers",
		"vitest": "catalog:silkPeers"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
