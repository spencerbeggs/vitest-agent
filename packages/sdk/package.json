{
	"name": "@vitest-agent/sdk",
	"version": "1.3.2",
	"private": true,
	"description": "Shared Effect Schema, SQLite migrations, data layer, services, formatters, and utilities for vitest-agent packages.",
	"keywords": ["vitest", "agent", "shared", "effect", "sqlite"],
	"homepage": "https://github.com/spencerbeggs/vitest-agent#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/vitest-agent/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/vitest-agent.git",
		"directory": "packages/sdk"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./dispatch": "./src/dispatch.ts",
		"./testing": "./src/testing/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "turbo run build:dev",
		"types:check": "tsgo --noEmit"
	},
	"dependencies": {
		"@effect/cluster": "catalog:silk",
		"@effect/experimental": "catalog:silk",
		"@effect/platform": "catalog:silk",
		"@effect/platform-node": "catalog:silk",
		"@effect/rpc": "catalog:silk",
		"@effect/sql": "catalog:silk",
		"@effect/sql-sqlite-node": "catalog:silk",
		"@effect/workflow": "catalog:silk",
		"@types/acorn": "^6.0.4",
		"acorn": "^8.17.0",
		"acorn-typescript": "^1.4.13",
		"ajv": "^8.20.0",
		"config-file-effect": "^0.3.0",
		"effect": "catalog:silk",
		"std-env": "^4.2.0",
		"workspaces-effect": "^2.0.2",
		"xdg-effect": "^2.1.1"
	},
	"devDependencies": {
		"@savvy-web/bundler": "^1.1.8",
		"@types/node": "catalog:silk",
		"@typescript/native-preview": "catalog:silk",
		"@vitest/coverage-v8": "catalog:silk",
		"typescript": "catalog:silk",
		"vitest": "catalog:silk"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
