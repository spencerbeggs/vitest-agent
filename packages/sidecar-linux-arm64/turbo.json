{
	"$schema": "https://turborepo.com/schema.v2.json",
	"extends": ["//"],
	"tasks": {
		"build:dev": {
			"cache": true,
			"dependsOn": ["^build:dev"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"$TURBO_ROOT$/package.json",
				"$TURBO_ROOT$/pnpm-lock.yaml",
				"$TURBO_ROOT$/pnpm-workspace.yaml",
				"src/**",
				"package.json",
				"tsdown.config.ts"
			],
			"outputLogs": "full",
			"outputs": ["dist/**", "bin/**"]
		},
		"build:prod": {
			"cache": true,
			"dependsOn": ["build:dev"],
			"inputs": [],
			"outputLogs": "full",
			"outputs": []
		},
		"types:check": {
			"cache": true,
			"dependsOn": [],
			"inputs": [],
			"outputLogs": "full",
			"outputs": []
		}
	}
}
