{
	"extends": ["//"],
	"tasks": {
		"build": {
			"cache": false,
			"dependsOn": [
				"vitest-agent-sdk#build:meta",
				"vitest-agent-plugin#build:meta",
				"vitest-agent-reporter#build:meta",
				"vitest-agent-ui#build:meta",
				"vitest-agent-cli#build:meta",
				"vitest-agent-mcp#build:meta"
			],
			"outputLogs": "full",
			"outputs": ["dist/**"]
		},
		"dev": {
			"cache": false,
			"dependsOn": ["^build:meta"],
			"persistent": true
		},
		"preview": {
			"cache": false,
			"dependsOn": ["build"],
			"persistent": true
		}
	}
}
