{
	"$schema": "https://unpkg.com/@changesets/config@3.1.1/schema.json",
	"changelog": [
		"@savvy-web/silk/changesets/changelog",
		{
			"repo": "spencerbeggs/vitest-agent",
			"packages": {
				"@vitest-agent/plugin": {
					"versionFiles": [
						{
							"glob": "plugin/.claude-plugin/plugin.json",
							"paths": ["$.version"]
						}
					]
				}
			}
		}
	],
	"commit": false,
	"access": "public",
	"baseBranch": "main",
	"updateInternalDependencies": "patch",
	"fixed": [
		[
			"@vitest-agent/plugin",
			"@vitest-agent/reporter",
			"@vitest-agent/sdk",
			"@vitest-agent/ui",
			"@vitest-agent/cli",
			"@vitest-agent/mcp",
			"@vitest-agent/sidecar",
			"@vitest-agent/sidecar-darwin-arm64",
			"@vitest-agent/sidecar-linux-arm64",
			"@vitest-agent/sidecar-linux-x64",
			"@vitest-agent/sidecar-win32-x64"
		]
	],
	"ignore": ["playground"],
	"privatePackages": {
		"tag": true,
		"version": true
	}
}
