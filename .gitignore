**/.DS_Store
**/node_modules
**/*.tsbuildinfo

# Generated TypeScript declaration files for config files
*.config.d.ts
**/build
**/dist
**/.rslib
**/.artifacts
**/.turbo
**/.coverage
**/.vitest
**/.cache
coverage/
**/*.asc
pnpm-publish-summary.json
pnpm-release.json
.changeset/status.json

# Environment files (keep .example files committed)
.env
.env.local
.env.development
.env.production
.env.test
.env.workflow
.env.workflow-cli
!.env.example
!.env.*.example

# Claude AI files
.claude/settings.local.json
.claude/plans/
.claude/cache/
.claude/plugins-debug.log
.playwright-mcp
docs/superpowers/
.mcp.json
# vitest-agent-reporter cache (standalone mode default; plugin mode uses node_modules/.vite/)
.vitest-agent-reporter/

# Git worktrees
.worktrees/

# Local plugin development
.vitest-agent-reporter-db

# Raw upstream Vitest docs work area (populated by lib/scripts/fetch-upstream-docs.ts)
packages/mcp/lib/vitest-docs-raw/

# Local spike harnesses — empirical evidence captured in
# .claude/plans/archive/ memos; the harness scripts themselves are
# reproducible from the memo's prose and not tracked in git.
spike/
.claude/scheduled_tasks.lock

# Superpowers brainstorm session artifacts (mockups, visual-companion state).
.superpowers/

# Per-platform vitest-agent-sidecar SEA binaries — built by CI, shipped
# inside the published sub-package, never committed to git.
packages/sidecar-*/bin/

# Docs ignores
website/lib/models/*
website/docs/en/*/api/
website/api-docs-snapshot.db-*
